#!/bin/bash
# Helper script to start a local HTTP server for the Viewer
# This bypasses the CORS restrictions when reading local JSON files via fetch()

PORT={{ viewer_port | default(8080) }}
echo "[Viewer] Starting local HTTP server on port $PORT..."
echo "[Viewer] Open http://localhost:$PORT/viewer.html in your browser."
echo "[Viewer] Press Ctrl+C to stop the server."

# Run python http.server in the current directory (which should be output/)
python3 -m http.server $PORT
