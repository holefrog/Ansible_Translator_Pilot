# Translator-Pilot Settings Configured dynamically via Ansible deployment template

[provider]
stt = "{{ stt_provider | mandatory }}"
translate = "{{ translate_provider | mandatory }}"
tts = "{{ tts_provider | mandatory }}"

[stt.common]
timeout = {{ api_timeout | mandatory }}
prompt = {{ lookup('file', stt_prompt_path) | to_json }}

[stt.groq_whisper]
api_key = "{{ groq_api_key | mandatory }}"
model = "{{ groq_model | mandatory }}"

[stt.gemini]
api_key = "{{ gemini_api_key | mandatory }}"
model = "{{ gemini_model | mandatory }}"

[translate.common]
system_prompt = """{{ llm_system_prompt | mandatory | trim }}"""
style_guide = {{ lookup('file', llm_style_guide_path) | to_json }}
user_prompt = """{{ llm_user_prompt | mandatory | trim }}"""
timeout = {{ api_timeout | mandatory }}
batch_size = {{ api_batch_size | mandatory }}
temperature = {{ api_temperature | mandatory }}
max_tokens = {{ api_max_tokens | mandatory }}
enable_cache = {{ 'true' if enable_translate_cache else 'false' }}

[translate.groq_llm]
api_key = "{{ groq_api_key | mandatory }}"
model = "{{ groq_llm_model | mandatory }}"

[translate.nvidia_llm]
api_key = "{{ nvidia_api_key | mandatory }}"
model = "{{ nvidia_llm_model | mandatory }}"

[translate.gemini]
api_key = "{{ gemini_api_key | mandatory }}"
model = "{{ gemini_model | mandatory }}"

[translate.openai]
api_key = "{{ openai_api_key | mandatory }}"
model = "{{ openai_model | mandatory }}"

[translate.mistral]
api_key = "{{ mistral_api_key | mandatory }}"
model = "{{ mistral_model | mandatory }}"

[tts.common]
timeout = {{ api_timeout | mandatory }}
enable_cache = {{ 'true' if enable_tts_cache else 'false' }}

[tts.azure_speech]
api_key = "{{ azure_speech_key | mandatory }}"
region = "{{ azure_speech_region | mandatory }}"
voice = "{{ azure_speech_voice | mandatory }}"

[tts.gemini_tts]
api_key = "{{ gemini_api_key | mandatory }}"
model = "{{ gemini_tts_model | mandatory }}"
voice = "{{ gemini_tts_voice | mandatory }}"

[tts.nvidia_magpie]
api_key = "{{ nvidia_api_key | mandatory }}"
language = "{{ nvidia_tts_language | mandatory }}"
voice = "{{ nvidia_tts_voice | mandatory }}"
sample_rate_hz = {{ nvidia_tts_sample_rate_hz | mandatory }}

[tts.sherpa_onnx]
model_dir = "{{ tts_sherpa_onnx_model_dir | mandatory }}"
vocoder_path = "{{ tts_sherpa_onnx_vocoder | mandatory }}"
num_threads = {{ tts_sherpa_onnx_num_threads | mandatory }}
volume_gain = {{ tts_sherpa_onnx_volume_gain | mandatory }}
phone_fst = "{{ tts_sherpa_onnx_phone_fst | default('phone.fst') }}"
date_fst = "{{ tts_sherpa_onnx_date_fst | default('date.fst') }}"
number_fst = "{{ tts_sherpa_onnx_number_fst | default('number.fst') }}"

[retry]
max_retries = {{ retry_max_retries | mandatory }}
base_delay = {{ retry_base_delay | mandatory }}
backoff_factor = {{ retry_backoff_factor | mandatory }}
max_delay = {{ retry_max_delay | mandatory }}

[rate_limit]
tts_rps = {{ tts_rate_limit_rps | mandatory }}

[cache]
enable_translate_cache = {{ 'true' if enable_translate_cache else 'false' }}
enable_tts_cache = {{ 'true' if enable_tts_cache else 'false' }}

[align]
warning_threshold_ratio = {{ align_warning_threshold_ratio | mandatory }}
