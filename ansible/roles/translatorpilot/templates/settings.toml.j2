# Translator-Pilot Settings Configured dynamically via Ansible deployment template

[provider]
stt = "{{ stt_provider }}"
translate = "{{ translate_provider }}"
tts = "{{ tts_provider }}"

[stt.groq_whisper]
api_key = "{{ groq_api_key }}"
model = "{{ groq_model }}"

[stt.gemini]
api_key = "{{ gemini_api_key }}"
model = "{{ gemini_model }}"

[translate.gemini]
api_key = "{{ gemini_api_key }}"
model = "{{ gemini_model }}"

[tts.azure_speech]
api_key = "{{ azure_speech_key }}"
region = "{{ azure_speech_region }}"
voice = "{{ azure_speech_voice }}"

[tts.gemini_tts]
voice = "{{ gemini_tts_voice }}"

[retry]
max_retries = {{ retry_max_retries }}
base_delay = {{ retry_base_delay }}
backoff_factor = {{ retry_backoff_factor }}
max_delay = {{ retry_max_delay }}

[align]
warning_threshold_ratio = {{ align_warning_threshold_ratio }}
